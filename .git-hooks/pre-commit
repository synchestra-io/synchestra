#!/bin/sh
# To setup git hooks run:
#   > git config core.hooksPath .git-hooks || echo 'Not in a git repo'
echo "Running .git-hooks/pre-commit..."

# .github/README.md overrides the root README.md on GitHub's repository page.
# Block commits that add or modify this file.
if git diff --name-only --cached | grep -qi "^\.github/readme\.md$"; then
  echo "ERROR: .github/README.md must NOT exist — it overrides the root README.md on GitHub."
  echo "See .github/README.not.md for details."
  exit 1
fi

if git diff --name-only --cached | grep -q ":\s*go\.mod"; then
  gomodlint
  exit_code=$?
  if [ $exit_code -ne 0 ]; then
    exit $exit_code
  fi
fi
go fmt ./...
go build ./...
go test  ./...
golangci-lint run
