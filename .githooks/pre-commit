#!/usr/bin/env bash
# Pre-commit hook: enforce AGENTS.md directory rules
# Install: git config core.hooksPath .githooks

set -euo pipefail

# Rule: Every directory MUST have a README.md, except .github/
# Check: any new directory introduced by staged files must include a README.md

# Get all directories that will exist after this commit (from staged files)
new_dirs=$(git diff --cached --name-only --diff-filter=A | xargs -I{} dirname {} | sort -u)

for dir in $new_dirs; do
    # Skip .github and root
    [[ "$dir" == "." ]] && continue
    [[ "$dir" == .github* ]] && continue

    # Check if README.md exists in this directory — either already tracked or being added
    if ! git ls-files --cached "$dir/README.md" | grep -q .; then
        echo "ERROR: Directory '$dir/' is missing a README.md (required by AGENTS.md)"
        echo "  Every directory must have a README.md with an Outstanding Questions section."
        echo ""
        echo "  To fix: create $dir/README.md before committing."
        exit 1
    fi
done
